{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "crons": [
    {
      "path": "/api/cron/tick",
      "schedule": "0 * * * *"
    },
    {
      "path": "/api/cron/proactive",
      "schedule": "0 */4 * * *"
    },
    {
      "path": "/api/cron/morning-brief",
      "schedule": "0 3 * * *"
    },
    {
      "path": "/api/cron/engagement-brief",
      "schedule": "0 4 * * *"
    },
    {
      "path": "/api/cron/comment-digest",
      "schedule": "0 */6 * * *"
    },
    {
      "path": "/api/cron/reminders",
      "schedule": "0 8 * * *"
    }
  ]
}
